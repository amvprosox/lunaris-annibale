From 55388ff0a7de59e7a085c49651c8e882f847cd55 Mon Sep 17 00:00:00 2001
From: chandu078 <chandudyavanapelli03@gmail.com>
Date: Fri, 20 Mar 2026 12:00:11 +0000
Subject: [PATCH] compat: Introduce libtinyxml2 v36

 * libtinyxml2 10.1.0 update which landed in BP4A contains ABI
   incompatible changes which cause runtime crashes.

 * Provide a renamed one so linker finds only one matching
   SONAME.

 * Copy the libraries built from android-16.0.0_r1 tag,
   rename, and --set-soname w/ patchelf.

Change-Id: I6f89166a8939555ffaaf64e5cfbf09c18c3913c3
---
 Android.bp                        |  24 ++++++++++++++++++++++++
 vndk/v36/arm/libtinyxml2-v36.so   | Bin 0 -> 100305 bytes
 vndk/v36/arm64/libtinyxml2-v36.so | Bin 0 -> 212977 bytes
 3 files changed, 24 insertions(+)
 create mode 100644 vndk/v36/arm/libtinyxml2-v36.so
 create mode 100755 vndk/v36/arm64/libtinyxml2-v36.so

diff --git a/Android.bp b/Android.bp
index 5069d3a..16d2ec7 100644
--- a/Android.bp
+++ b/Android.bp
@@ -634,6 +634,30 @@ cc_prebuilt_library_shared {
     compile_multilib: "both",
 }
 
+cc_prebuilt_library_shared {
+    name: "libtinyxml2-v36",
+    vendor: true,
+    strip: {
+        none: true,
+    },
+    shared_libs: [
+        "liblog",
+        "libc++",
+        "libc",
+        "libm",
+        "libdl",
+    ],
+    target: {
+        android_arm: {
+            srcs: ["vndk/v36/arm/libtinyxml2-v36.so"],
+        },
+        android_arm64: {
+            srcs: ["vndk/v36/arm64/libtinyxml2-v36.so"],
+        },
+    },
+    compile_multilib: "both",
+}
+
 cc_library_shared {
     name: "libcomparetf2_shim",
     srcs: ["libcomparetf2/comparetf2.c"],
diff --git a/vndk/v36/arm/libtinyxml2-v36.so b/vndk/v36/arm/libtinyxml2-v36.so
new file mode 100644
index 0000000000000000000000000000000000000000..7055df043718013db15b3999e0b26b5499024bbf
