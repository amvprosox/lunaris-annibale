From debdb269ce251790440340e8b3a42d6ab15f066e Mon Sep 17 00:00:00 2001
From: ramshell688 <ramonzost68@gmail.com>
Date: Fri, 27 Mar 2026 21:49:43 +0700
Subject: [PATCH] [DNM]Aperture: Set value Support JPEG Ultra HDR capture to
 false

Change-Id: I31b14a8a393a0ed2a53865d528a2a1a297946495
---
 .../lineageos/aperture/repositories/PreferencesRepository.kt    | 2 +-
 app/src/main/res/xml/root_preferences.xml                       | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/app/src/main/java/org/lineageos/aperture/repositories/PreferencesRepository.kt b/app/src/main/java/org/lineageos/aperture/repositories/PreferencesRepository.kt
index 5cabc85..92d34a0 100644
--- a/app/src/main/java/org/lineageos/aperture/repositories/PreferencesRepository.kt
+++ b/app/src/main/java/org/lineageos/aperture/repositories/PreferencesRepository.kt
@@ -144,7 +144,7 @@ class PreferencesRepository(
      */
     val usePhotoJpegUltraHdr = primitivePreference(
         key = "use_photo_jpeg_ultra_hdr",
-        defaultValue = true,
+        defaultValue = false,
     ).asPreferenceHolder()
 
     /**
diff --git a/app/src/main/res/xml/root_preferences.xml b/app/src/main/res/xml/root_preferences.xml
index e3f847b..a19c82a 100644
--- a/app/src/main/res/xml/root_preferences.xml
+++ b/app/src/main/res/xml/root_preferences.xml
@@ -65,7 +65,7 @@
             app:title="@string/enable_zsl_title" />
 
         <SwitchPreference
-            app:defaultValue="true"
+            app:defaultValue="false"
             app:iconSpaceReserved="false"
             app:key="use_photo_jpeg_ultra_hdr"
             app:summary="@string/use_photo_jpeg_ultra_hdr_summary"
-- 
2.34.1

